{
  "name": "gradeflow-functions",
  "description": "GradeFlow Cloud Functions — transcription, rubric generation, and grading",
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "@ehomework/gradeflow-shared": "file:./packages/gradeflow-shared",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.0.0"
  },
  "scripts": {
    "serve": "cd .. && firebase emulators:start --only functions",
    "deploy": "cd .. && firebase deploy --only functions",
    "logs": "cd .. && firebase functions:log"
  }
}
