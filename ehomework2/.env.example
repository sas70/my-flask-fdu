# Next.js (local) — copy to .env.local
# Firebase Admin (server API routes): full service account JSON on one line
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Or the same JSON in:
# FIREBASE_SERVICE_ACCOUNT_KEY_JSON={...}
# Public Firebase client config can use NEXT_PUBLIC_* when you add the client SDK.

# Cloud Functions use Firebase secrets / emulator env — not this file in production.
# For local Functions emulator, set the same keys in functions/.env or shell:
# GOOGLE_API_KEY=
# Optional: Gemini model id for homework video transcription (Cloud Functions / emulator). Default: gemini-2.5-flash
# GEMINI_TRANSCRIPTION_MODEL=
#
# Next.js (tab capture): per-segment transcription calls Gemini from /api/admin/homework-capture/chunk-transcribe — set the same in .env.local / Vercel:
# GOOGLE_API_KEY=
# GEMINI_TRANSCRIPTION_MODEL=
# ANTHROPIC_API_KEY=
# SECRET_BYTESCALE_API_KEY=
# BYTESCALE_ACCOUNT_ID=

# ByteScale — required for admin discussion response uploads (full text stored at URL, not in Firestore)
# SECRET_BYTESCALE_API_KEY=
# BYTESCALE_ACCOUNT_ID=

# Admin auth — simple password-based login for the instructor
ADMIN_PASSWORD=
ADMIN_SESSION_TOKEN=

# Optional: browser tab capture chunk length (ms). Default 60000 (1 min). Lower if Vercel returns 413 on chunk upload.
# NEXT_PUBLIC_HOMEWORK_CAPTURE_CHUNK_MS=45000
