# Flask base or full detect URL (server-side proxy). Optional in dev: defaults to http://127.0.0.1:5050/api/detect
# Examples: http://127.0.0.1:5050  OR  http://127.0.0.1:5050/api/detect
FLASK_DETECT_URL=

# Optional: form field name Flask reads for the upload (default: file). Set to image if your route uses request.files["image"].
# FLASK_DETECT_FILE_FIELD=file
# Optional: also send the same file under this name (default: image). Leave unset or set to same as primary to send only once.
# FLASK_DETECT_FILE_FIELD_ALT=image

# Public base URL of this Next app so Flask can fetch hosted uploads (must match what Flask can reach).
# Local: http://127.0.0.1:3000
# Dockerized Flask on Mac often needs: http://host.docker.internal:3000
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
